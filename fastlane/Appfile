# VoiceIsolate Pro — Fastlane Appfile

# iOS
app_identifier("com.voiceisolatepro.app")
apple_id(ENV["APPLE_ID"] || "")
team_id(ENV["APPLE_TEAM_ID"] || "")

# Android
json_key_file(ENV["GOOGLE_PLAY_JSON_KEY"] || "")
package_name("com.voiceisolatepro.app")

# Shared
for_platform :ios do
  app_identifier "com.voiceisolatepro.app"
end

for_platform :android do
  package_name "com.voiceisolatepro.app"
end
