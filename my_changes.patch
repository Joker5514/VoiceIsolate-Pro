+      return await this._mlCall({ type: 'process', model, signal, sampleRate: buf.sampleRate }, [signal.buffer]);
+    } catch (e) {
+      structuredLog('warn', 'ML separation failed', { error: e.message });
+      return buf;
+    }
+  }
