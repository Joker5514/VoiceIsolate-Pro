+  const dstNyquist = 8000; // 16 kHz / 2
+  const freqScale = dstNyquist / srcNyquist;
+
+  for (let k = 0; k < dns2Bins; k++) {
+    const srcK = Math.round(k / freqScale);
+    output[k] = srcK < srcBins ? srcFrame[srcK] : 0;
+  }
+  return output;
+}
