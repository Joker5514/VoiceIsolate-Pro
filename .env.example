# VoiceIsolate Pro — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys for local development; only use live keys in production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create products in Stripe Dashboard first
# https://dashboard.stripe.com/products
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_STUDIO_MONTHLY=price_...
STRIPE_PRICE_STUDIO_ANNUAL=price_...

# ─── License JWT ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
LICENSE_JWT_SECRET=your-secret-key-min-32-chars

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (required for production; in-memory store used otherwise) ───────
# DATABASE_URL=postgresql://user:password@host:5432/voiceisolate
