{
  "framework": null,
  "outputDirectory": "public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "node scripts/setup-ort.js",
  "env": {
    "PUPPETEER_SKIP_DOWNLOAD": "true",
    "PUPPETEER_SKIP_CHROMIUM_DOWNLOAD": "true",
    "NODE_ENV": "production"
  },
  "github": {
    "autoJobCancelation": false
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/handler"
    },
    {
      "source": "/app/((?!sw\\.js).*)",
      "destination": "/app/index.html"
    },
    {
      "source": "/app",
      "destination": "/app/index.html"
    },
    {
      "source": "/((?!api/|lib/|assets/|app/|sw\\.js|manifest\\.json|icon\\.jpg|favicon\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/((?!api/).*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy",   "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" },
        { "key": "X-Frame-Options",              "value": "DENY" },
        { "key": "X-Content-Type-Options",       "value": "nosniff" },
        { "key": "Strict-Transport-Security",    "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy",           "value": "microphone=(self), camera=(), geolocation=(), payment=(), usb=()" },
        { "key": "Referrer-Policy",              "value": "strict-origin-when-cross-origin" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' /_vercel/; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; media-src 'self' blob: mediastream:; connect-src 'self' blob: https://va.vercel-scripts.com https://blob.vercel-storage.com https://*.public.blob.vercel-storage.com; worker-src 'self' blob:; frame-ancestors 'none'"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Content-Type",  "value": "application/javascript" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/app/sw.js",
      "headers": [
        { "key": "Content-Type",           "value": "application/javascript" },
        { "key": "Cache-Control",          "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/app/" }
      ]
    },
    {
      "source": "/app/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy",   "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    },
    {
      "source": "/app/dsp-processor.js",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy",   "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" },
        { "key": "Content-Type",  "value": "application/javascript" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/app/models/(.*\\.onnx)",
      "headers": [
        { "key": "Content-Type",                 "value": "application/octet-stream" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" },
        { "key": "Cache-Control",                "value": "public, max-age=86400, immutable" }
      ]
    },
    {
      "source": "/lib/(.*\\.wasm)",
      "headers": [
        { "key": "Content-Type",                 "value": "application/wasm" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" },
        { "key": "Cache-Control",                "value": "public, max-age=86400, immutable" }
      ]
    },
    {
      "source": "/lib/(.*\\.js)",
      "headers": [
        { "key": "Content-Type",                 "value": "application/javascript" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" },
        { "key": "Cache-Control",                "value": "public, max-age=86400" }
      ]
    }
  ]
}
