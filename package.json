{
  "name": "voiceisolate-pro",
  "version": "19.0.0",
  "type": "module",
  "description": "Studio-grade voice isolation platform. 32-stage Octa-Pass DSP pipeline with hybrid ML + classical spectral processing.",
  "private": true,
  "keywords": [
    "audio",
    "dsp",
    "voice-isolation",
    "noise-reduction",
    "web-audio",
    "machine-learning"
  ],
  "author": "VoiceIsolate Pro",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "npx serve public -l 3000 --cors",
    "build": "rm -rf build && mkdir build && cp -r public/* build/ && cp index.html style.css app.js build/",
    "lint": "eslint public/app/app.js public/app/dsp-worker.js public/app/ml-worker.js",
    "lint:fix": "eslint public/app/app.js public/app/dsp-worker.js public/app/ml-worker.js --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testEnvironment=node",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testEnvironment=node --watch",
    "validate": "node scripts/validate.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "public/app/app.js",
      "public/app/dsp-worker.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
